{
  "header": "escovid19data",
    "geoinfo": {
    "granularity": "subregion",
    "iso3": "ESP",
    "locationmode":"name"
  },
   "replace":{
      "Alicante/Alacant":"Alicante",
      "Araba/Álava":"Araba",
      "Castellón/Castelló":"Castelló",
      "Valencia/València":"València",
      "Rioja, La":"La Rioja",
      "Alicante/Alacant":"Alacant",
      "Gipuzkoa":"Gipuzcoa",
      "Coruña":"La Coruña"
  },

  "datasets": [
  	{	
	 "urldata": "https://zenodo.org/records/11222021/files/escovid19data_covid19-provincias-spain_consolidated.csv?content",
	 "urlparent":"https://raw.githubusercontent.com/montera34/escovid19data/master/data/output/covid19-provincias-spain_consolidated.csv",
	 "separator":",",
  	 "columns": [
    			{
		   "name":"where",
    		   "alias":"province"	
			},
			{
			"name":"date"
             	       },
		       {"alias":"deceased","name":"tot_deaths"},
                       {"alias":"cases_accumulated","name":"tot_cases"},
                       {"alias":"activos","name":"cur_cases"},
                       {"alias":"hospitalized","name":"cur_hosp"},
                       {"alias":"hospitalized_accumulated","name":"tot_hosp"},
                       {"alias":"intensive_care","name":"cur_icu"},
                       {"alias":"recovered","name":"tot_recovered"}
	 ]
	}
  ]
}  
